# Auto detect text files and normalize line endings to LF
* text=auto

# Shell scripts must always use LF
*.sh text eol=lf

# Docker files must use LF
Dockerfile text eol=lf
docker-entrypoint.sh text eol=lf

# Python files should use LF
*.py text eol=lf

# Web files should use LF
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.vue text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
